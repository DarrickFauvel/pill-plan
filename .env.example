# For local development without a Turso account, use a local SQLite file:
TURSO_URL=file:local.db
TURSO_AUTH_TOKEN=

# For production, use your Turso database URL:
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

SESSION_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development

# Stripe — create keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Price ID from your Stripe product (Stripe dashboard → Products → your price ID)
STRIPE_PRICE_ID=price_...
# Webhook signing secret (Stripe dashboard → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Public URL used for Stripe redirect URLs (e.g. https://medigrid.example.com)
SITE_URL=http://localhost:3000

# Comma-separated emails that can access /admin
ADMIN_EMAILS=you@example.com
