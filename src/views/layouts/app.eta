<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#6EC6A0">
  <meta name="description" content="Your medication organizer">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/app.css">
  <% if (it.extraCss) { %><link rel="stylesheet" href="<%= it.extraCss %>"><% } %>
  <title><%= it.title ? it.title + ' — MediGrid' : 'MediGrid' %></title>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <div class="app-shell">

    <!-- Mobile-only top header -->
    <header class="app-header" role="banner">
      <a href="/app/grid" class="app-brand"><span class="logo-plus">+</span> MediGrid</a>

      <div class="app-header__actions">
        <button class="qr-btn" aria-label="Open on another device" onclick="document.getElementById('qr-modal').showModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect width="5" height="5" x="3" y="3" rx="1"/>
            <rect width="5" height="5" x="16" y="3" rx="1"/>
            <rect width="5" height="5" x="3" y="16" rx="1"/>
            <path d="M21 16h-3a2 2 0 0 0-2 2v3"/>
            <path d="M21 21v.01"/>
            <path d="M12 7v3a2 2 0 0 1-2 2H7"/>
            <path d="M3 12h.01"/>
            <path d="M12 3h.01"/>
            <path d="M12 16v.01"/>
            <path d="M16 12h1"/>
            <path d="M21 12v.01"/>
            <path d="M12 21v-1"/>
          </svg>
        </button>

      <!-- Profile switcher (mobile header) -->
      <details-menu>
      <details class="profile-switcher" id="profile-switcher-header">
        <summary
          class="profile-switcher__trigger"
          aria-label="Switch profile — active: <%= it.profile.name %>"
        >
          <span
            class="profile-avatar"
            style="--avatar-color: <%= it.profile.avatarColor %>;"
            aria-hidden="true"
          ><%= it.profile.name.charAt(0).toUpperCase() %></span>
          <span class="profile-switcher__name"><%= it.profile.name %></span>
          <svg class="profile-switcher__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="profile-switcher__menu" role="menu">
          <% it.profiles.forEach(function(p) { %>
          <form action="/app/profiles/switch/<%= p.id %>" method="POST" role="none">
            <button
              type="submit"
              class="profile-option<%= p.id === it.profile.id ? ' profile-option--active' : '' %>"
              role="menuitem"
              aria-current="<%= p.id === it.profile.id ? 'true' : 'false' %>"
            >
              <span
                class="profile-avatar"
                style="--avatar-color: <%= p.avatarColor %>;"
                aria-hidden="true"
              ><%= p.name.charAt(0).toUpperCase() %></span>
              <%= p.name %>
            </button>
          </form>
          <% }); %>
          <a href="/app/profiles/new" class="profile-option profile-option--new" role="menuitem">
            + Add profile
          </a>
          <form action="/api/auth/logout" method="POST" role="none">
            <button type="submit" class="profile-option profile-option--signout" role="menuitem">
              Sign out
            </button>
          </form>
        </div>
      </details>
      </details-menu>
      </div><!-- /.app-header__actions -->
    </header>

    <!-- Desktop sidebar (hidden on mobile) -->
    <nav class="app-sidebar" aria-label="Main navigation">
      <a href="/app/grid" class="app-brand"><span class="logo-plus">+</span> MediGrid</a>

      <!-- Profile switcher (sidebar) -->
      <details-menu>
      <details class="profile-switcher profile-switcher--sidebar" id="profile-switcher-sidebar">
        <summary
          class="profile-switcher__trigger"
          aria-label="Switch profile — active: <%= it.profile.name %>"
        >
          <span
            class="profile-avatar"
            style="--avatar-color: <%= it.profile.avatarColor %>;"
            aria-hidden="true"
          ><%= it.profile.name.charAt(0).toUpperCase() %></span>
          <span class="profile-switcher__name"><%= it.profile.name %></span>
          <svg class="profile-switcher__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="profile-switcher__menu profile-switcher__menu--sidebar" role="menu">
          <% it.profiles.forEach(function(p) { %>
          <form action="/app/profiles/switch/<%= p.id %>" method="POST" role="none">
            <button
              type="submit"
              class="profile-option<%= p.id === it.profile.id ? ' profile-option--active' : '' %>"
              role="menuitem"
              aria-current="<%= p.id === it.profile.id ? 'true' : 'false' %>"
            >
              <span
                class="profile-avatar"
                style="--avatar-color: <%= p.avatarColor %>;"
                aria-hidden="true"
              ><%= p.name.charAt(0).toUpperCase() %></span>
              <%= p.name %>
            </button>
          </form>
          <% }); %>
          <a href="/app/profiles/new" class="profile-option profile-option--new" role="menuitem">
            + Add profile
          </a>
        </div>
      </details>
      </details-menu>

      <ul class="app-nav" role="list">
        <li>
          <a
            href="/app/grid"
            class="app-nav__link<%= it.path === '/app/grid' ? ' app-nav__link--active' : '' %>"
            aria-current="<%= it.path === '/app/grid' ? 'page' : 'false' %>"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
            </svg>
            Grid
          </a>
        </li>
        <li>
          <a
            href="/app/medications"
            class="app-nav__link<%= it.path === '/app/medications' ? ' app-nav__link--active' : '' %>"
            aria-current="<%= it.path === '/app/medications' ? 'page' : 'false' %>"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="M8.5 8.5 16 16"/>
            </svg>
            Medications
          </a>
        </li>
        <li>
          <a
            href="/app/settings"
            class="app-nav__link<%= it.path === '/app/settings' ? ' app-nav__link--active' : '' %>"
            aria-current="<%= it.path === '/app/settings' ? 'page' : 'false' %>"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>
            </svg>
            Settings
          </a>
        </li>
      </ul>

      <div class="app-sidebar__footer">
        <button class="qr-btn" aria-label="Open on another device" onclick="document.getElementById('qr-modal').showModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect width="5" height="5" x="3" y="3" rx="1"/>
            <rect width="5" height="5" x="16" y="3" rx="1"/>
            <rect width="5" height="5" x="3" y="16" rx="1"/>
            <path d="M21 16h-3a2 2 0 0 0-2 2v3"/>
            <path d="M21 21v.01"/>
            <path d="M12 7v3a2 2 0 0 1-2 2H7"/>
            <path d="M3 12h.01"/>
            <path d="M12 3h.01"/>
            <path d="M12 16v.01"/>
            <path d="M16 12h1"/>
            <path d="M21 12v.01"/>
            <path d="M12 21v-1"/>
          </svg>
          <span>Open on another device</span>
        </button>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="btn btn--secondary btn--full">Sign out</button>
        </form>
      </div>
    </nav>

    <!-- Main content -->
    <main id="main" class="app-main">
      <%~ it.body %>
    </main>

    <!-- Mobile-only bottom nav -->
    <nav class="app-bottom-nav" aria-label="Main navigation">
      <a
        href="/app/grid"
        class="app-bottom-nav__item<%= it.path === '/app/grid' ? ' app-bottom-nav__item--active' : '' %>"
        aria-current="<%= it.path === '/app/grid' ? 'page' : 'false' %>"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
        </svg>
        <span>Grid</span>
      </a>
      <a
        href="/app/medications"
        class="app-bottom-nav__item<%= it.path === '/app/medications' ? ' app-bottom-nav__item--active' : '' %>"
        aria-current="<%= it.path === '/app/medications' ? 'page' : 'false' %>"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="M8.5 8.5 16 16"/>
        </svg>
        <span>Medications</span>
      </a>
      <a
        href="/app/settings"
        class="app-bottom-nav__item<%= it.path === '/app/settings' ? ' app-bottom-nav__item--active' : '' %>"
        aria-current="<%= it.path === '/app/settings' ? 'page' : 'false' %>"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        <span>Settings</span>
      </a>
    </nav>

  </div>

  <div
    id="save-indicator"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    data-signals='{"saveStatus":"idle"}'
    data-class='{"save-indicator--saving": $saveStatus === "saving", "save-indicator--saved": $saveStatus === "saved", "save-indicator--error": $saveStatus === "error"}'
    class="save-indicator"
  >
    <span data-show="$saveStatus === 'saving'">
      <span class="save-indicator__spinner" aria-hidden="true"></span>
      Saving…
    </span>
    <span data-show="$saveStatus === 'saved'">Saved</span>
    <span data-show="$saveStatus === 'error'">Not saved — check your connection</span>
  </div>

  <dialog id="qr-modal" class="qr-modal" aria-labelledby="qr-modal-title">
    <div class="qr-modal__inner">
      <div class="qr-modal__header">
        <h2 id="qr-modal-title" class="qr-modal__title">Open on another device</h2>
        <button class="qr-modal__close" aria-label="Close" onclick="this.closest('dialog').close()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <img src="/qrcode.svg" alt="QR code linking to MediGrid" class="qr-modal__code" width="256" height="256">
      <p class="qr-modal__hint">Scan with your phone camera to open MediGrid</p>
    </div>
  </dialog>

  <script>
    document.getElementById('qr-modal').addEventListener('click', function(e) {
      if (e.target === this) this.close();
    });
  </script>

  <script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.1/bundles/datastar.js"></script>
  <script type="module" src="/js/app.js"></script>
  <%~ it.scripts ?? '' %>
</body>
</html>
