<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#6EC6A0">
  <meta name="description" content="Your medication organizer">
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/grid.css">
  <% if (it.extraCss) { %><link rel="stylesheet" href="<%= it.extraCss %>"><% } %>
  <title><%= it.title ? it.title + ' — MediGrid' : 'MediGrid' %></title>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <%~ it.body %>

  <%~ it.saveIndicator !== false ? `
  <div
    id="save-indicator"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    data-signals='{"saveStatus":"idle"}'
    data-show="$saveStatus !== 'idle'"
    data-class='{"save-indicator--saving": $saveStatus === "saving", "save-indicator--saved": $saveStatus === "saved", "save-indicator--error": $saveStatus === "error"}'
    class="save-indicator"
  >
    <span data-show="$saveStatus === 'saving'">
      <span class="save-indicator__spinner" aria-hidden="true"></span>
      Saving…
    </span>
    <span data-show="$saveStatus === 'saved'">Saved</span>
    <span data-show="$saveStatus === 'error'">Not saved — check your connection</span>
  </div>
  ` : '' %>

  <script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.1/bundles/datastar.js"></script>
  <script type="module" src="/js/app.js"></script>
  <%~ it.scripts ?? '' %>
</body>
</html>
