<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#6EC6A0">
  <meta name="description" content="Your medication organizer">
  <link rel="manifest" href="/manifest.json">
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/grid.css">
  <% if (it.extraCss) { %><link rel="stylesheet" href="<%= it.extraCss %>"><% } %>
  <title><%= it.title ? it.title + ' — Pill Plan' : 'Pill Plan' %></title>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <%~ it.body %>

  <%~ it.saveIndicator !== false ? `
  <div
    id="save-indicator"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    data-signals='{"saveStatus":"idle"}'
    data-class='{"save-indicator--saved": $saveStatus === "saved", "save-indicator--error": $saveStatus === "error"}'
    class="save-indicator"
  >
    <span data-show="$saveStatus === 'saved'">Saved</span>
    <span data-show="$saveStatus === 'error'">Not saved — check your connection</span>
  </div>
  ` : '' %>

  <footer class="site-footer">
    <nav class="site-footer__links" aria-label="Legal">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
    </nav>
    <p>&copy; <%= new Date().getFullYear() %> Pill Plan</p>
  </footer>

  <script>
    (function () {
      const d = new Date();
      const pad = (n) => String(n).padStart(2, '0');
      const local = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
      document.cookie = `local-date=${local};path=/;SameSite=Lax;Secure;Max-Age=86400`;
    })();
  </script>
  <script type="module" src="/js/vendor/datastar.js"></script>
  <script type="module" src="/js/app.js"></script>
  <%~ it.scripts ?? '' %>
</body>
</html>
