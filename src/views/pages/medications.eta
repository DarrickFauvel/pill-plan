<% layout('../layouts/app') %>
<div class="medications-page">

  <header class="page-header">
    <h1>Medications</h1>
    <a href="/app/medications/print" class="btn btn--secondary" aria-label="Print medication list">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/>
      </svg>
      Print
    </a>
    <a href="/app/medications/new" class="btn btn--primary">Add medication</a>
  </header>

  <% if (it.meds.length === 0) { %>
    <div class="empty-state">
      <p class="empty-state__icon" aria-hidden="true">💊</p>
      <p class="empty-state__heading">No medications yet</p>
      <p class="empty-state__body">Add your first medication to start tracking your supply and refill schedule.</p>
      <a href="/app/medications/new" class="btn btn--primary">Add medication</a>
    </div>
  <% } else { %>
    <ul class="med-list" role="list">
      <% it.meds.forEach(function(med) { %>
        <li class="med-card">
          <div class="med-card__info">
            <h2 class="med-card__name"><%= med.name %></h2>
            <% if (med.strength || med.form) { %>
              <p class="med-card__meta"><%= med.strength %><% if (med.strength && med.form) { %> · <% } %><%= med.form %></p>
            <% } %>
          </div>

          <div class="med-card__stats">
            <% if (med.daysRemaining !== null) { %>
              <span class="days-badge<%= med.needsRefill ? ' days-badge--warning' : '' %>">
                <%= med.daysRemaining %> day<%= med.daysRemaining !== 1 ? 's' : '' %> left
              </span>
            <% } %>
          </div>

          <div class="med-card__actions">
            <a href="/app/medications/<%= med.id %>" class="btn btn--secondary">Edit</a>
            <confirm-dialog>
              <button type="button" class="btn btn--danger" data-trigger>Remove</button>
              <dialog class="confirm-modal" aria-labelledby="confirm-title-<%= med.id %>">
                <div class="confirm-modal__inner">
                  <h2 id="confirm-title-<%= med.id %>" class="confirm-modal__title">Remove <%= med.name %>?</h2>
                  <p class="confirm-modal__body">This will remove the medication from your grid and supply tracking.</p>
                  <div class="confirm-modal__actions">
                    <button type="button" class="btn btn--secondary" data-close>Cancel</button>
                    <form action="/api/medications/<%= med.id %>/deactivate" method="POST" style="display:contents">
                      <button type="submit" class="btn btn--danger">Yes, remove</button>
                    </form>
                  </div>
                </div>
              </dialog>
            </confirm-dialog>
          </div>
        </li>
      <% }); %>
    </ul>
  <% } %>

</div>
